# All settings are optional in development — unset values fall back to SQLite,
# in-process jobs, console email, AI stub and a fail-closed code runner.

# Database: SQLite (default) or Postgres from infra/docker-compose.yml
# (compose maps Postgres to host port 15432; PgBouncer on 6432)
TB_DATABASE_URL=sqlite+aiosqlite:///./testbuilder.db
# TB_DATABASE_URL=postgresql+asyncpg://testbuilder:testbuilder@localhost:15432/testbuilder

# Auth
TB_JWT_SECRET=change-me-to-a-long-random-string-32-bytes-min
TB_ACCESS_TOKEN_MINUTES=15

# Google Gemini (AI question generation, written-answer eval, summaries)
TB_GEMINI_API_KEY=
TB_GEMINI_MODEL=gemini-2.0-flash

# Judge0 CE (code execution) — docker compose exposes it on :2358
TB_JUDGE0_URL=
# TB_JUDGE0_URL=http://localhost:2358

# Resend (transactional email); unset = console transport
TB_RESEND_API_KEY=
TB_EMAIL_FROM=TestBuilder <no-reply@yourdomain.com>

# Object storage (S3/MinIO); unset = local disk ./storage_local
TB_S3_ENDPOINT=
TB_S3_BUCKET=testbuilder
TB_S3_ACCESS_KEY=
TB_S3_SECRET_KEY=

TB_FRONTEND_BASE_URL=http://localhost:3000
TB_CORS_ORIGINS=http://localhost:3000
