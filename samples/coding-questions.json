      "difficulty": "easy",
      "category": "Algorithms",
      "topic": "dynamic-programming",
      "tags": ["math", "recursion", "dp"],
      "answer_type": "code",
      "config": {
        "signature": {
          "function_name": "fib",
          "params": [{ "name": "n", "type": "int" }],
          "return_type": "int"
        },
        "allowed_languages": ["python", "javascript", "java", "cpp"],
        "description": "The **Fibonacci** numbers, commonly denoted `F(n)`, form a sequence where each number is the sum of the two preceding ones, starting from `0` and `1`:\n\n```\nF(0) = 0, F(1) = 1\nF(n) = F(n-1) + F(n-2)  for n > 1\n```\n\nGiven `n`, return `F(n)`.",
        "input_format": "- `n`: a non-negative integer",
        "output_format": "The n-th Fibonacci number.",
        "constraints": "- `0 <= n <= 30`",
        "examples": [
          { "input": "n = 2", "output": "1", "explanation": "F(2) = F(1) + F(0) = 1 + 0 = 1." },
          { "input": "n = 5", "output": "5", "explanation": "0, 1, 1, 2, 3, 5 — F(5) = 5." }
        ],
        "test_cases": [
          { "id": "s1", "args": [2], "expected": 1, "is_hidden": false, "weight": 1 },
          { "id": "s2", "args": [5], "expected": 5, "is_hidden": false, "weight": 1 },
          { "id": "h1", "args": [0], "expected": 0, "is_hidden": true, "weight": 1 },
          { "id": "h2", "args": [1], "expected": 1, "is_hidden": true, "weight": 1 },
          { "id": "h3", "args": [10], "expected": 55, "is_hidden": true, "weight": 1 },
          { "id": "h4", "args": [20], "expected": 6765, "is_hidden": true, "weight": 1 }
        ],
        "time_limit_ms": 5000,
        "memory_limit_kb": 256000,
        "show_case_results": "visible_only"
      }
    },
